  "type": "object",
  "required": [
    "caseId",
    "packageId",
    "packageVersion",
    "engine",
    "inputs",
    "outputs",
    "steps"
  ],
  "properties": {
    "caseId": {
      "type": "string"
    },
    "packageId": {
      "type": "string"
    },
    "packageVersion": {
      "type": "string"
    },
    "engine": {
      "type": "object"
    },
    "inputs": {
      "type": "object"
    },
    "outputs": {
      "type": "object"
    },
    "steps": {
      "type": "array"
    }
  }
}
