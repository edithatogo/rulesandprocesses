{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "@id",
    "@type",
    "label",
    "definition"
  ],
  "properties": {
    "@id": {
      "type": "string"
    },
    "@type": {
      "const": "racx:Concept"
    },
    "label": {
      "type": "string"
    },
    "definition": {
      "type": "string"
    },
    "sameAs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
