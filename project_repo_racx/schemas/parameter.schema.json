{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "@id",
    "@type",
    "values"
  ],
  "properties": {
    "@id": {
      "type": "string"
    },
    "@type": {
      "const": "racx:TemporalParameter"
    },
    "label": {
      "type": "string"
    },
    "unit": {
      "type": "string"
    },
    "values": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "value"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": [
              "string",
              "null"
            ]
          },
          "value": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "sourceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
