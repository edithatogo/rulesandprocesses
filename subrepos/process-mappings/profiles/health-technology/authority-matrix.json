  "nonEquivalenceRules": [
    {"id": "fda-is-not-payer", "forbid": {"authority": "fda", "role": "payer_coverage"}},
    {"id": "mbs-is-not-medicine-regulator", "forbid": {"authority": "mbs", "role": "market_authorisation"}},
    {"id": "msac-is-not-pbs", "forbid": {"authority": "msac", "role": "medicine_listing"}},
    {"id": "authorisation-is-not-funding", "forbid": {"role": "market_authorisation", "implies": "funding_decision"}},
    {"id": "advice-is-not-decision", "forbid": {"role": "hta_advice", "implies": "funding_decision"}}
  ]
