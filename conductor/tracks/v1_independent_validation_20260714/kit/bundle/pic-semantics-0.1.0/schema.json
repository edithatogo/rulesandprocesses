{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/edithatogo/rac-conformance/contracts/pic-semantics/0.1.0/schema.json",
  "title": "PIC semantics reusable definitions",
  "$defs": {
    "valueState": {
      "type": "string",
      "enum": [
        "known",
        "zero",
        "false",
        "unknown",
        "not_provided",
        "not_applicable",
        "provided_unverified",
        "verified_stale",
        "conflicting"
      ]
    },
    "epistemicStatus": {
      "type": "string",
      "enum": ["observed", "inferred", "asserted", "certified", "unknown"]
    },
    "dataType": {
      "type": "string",
      "enum": [
        "boolean",
        "integer",
        "decimal",
        "money",
        "string",
        "date",
        "enum",
        "duration_working_days",
        "duration_calendar_days"
      ]
    },
    "decimalString": {
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$"
    },
    "rounding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "scale"],
      "properties": {
        "mode": {"type": "string", "enum": ["half_up", "half_even", "floor", "ceil"]},
        "scale": {"type": "integer", "minimum": 0}
      }
    },
    "valueObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valueState"],
      "properties": {
        "value": {
          "oneOf": [
            {"type": "boolean"},
            {"type": "integer"},
            {"type": "string"}
          ]
        },
        "valueState": {"$ref": "#/$defs/valueState"},
        "epistemicStatus": {"$ref": "#/$defs/epistemicStatus"},
        "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
        "warnings": {"type": "array", "items": {"type": "string"}}
      },
      "allOf": [
        {
          "if": {"required": ["currency"]},
          "then": {
            "required": ["value"],
            "properties": {"value": {"$ref": "#/$defs/decimalString"}}
          }
        }
      ]
    }
  },
  "$ref": "#/$defs/valueObject"
}
