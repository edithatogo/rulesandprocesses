{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/edithatogo/rac-conformance/contracts/process-profile/0.1.0/schema.json",
  "title": "PIC process profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["conformsTo", "profileId", "profileVersion", "processDefinitionVersion", "jurisdiction", "applicableAt", "observedAt", "sourceAssertions", "actors", "states", "events", "timers", "transitions", "tasks", "ruleInvocations", "evidenceReferences", "traces"],
  "properties": {
    "conformsTo": {"const": "pic-process-profile/0.1.0"},
    "profileId": {"$ref": "#/$defs/picId"},
    "profileVersion": {"$ref": "#/$defs/semver"},
    "processDefinitionVersion": {"$ref": "#/$defs/semver"},
    "jurisdiction": {"type": "string", "pattern": "^[A-Z]{2}(?:-[A-Z0-9]{1,3})?$"},
    "applicableAt": {"type": "string", "format": "date-time"},
    "observedAt": {"type": "string", "format": "date-time"},
    "sourceAssertions": {"type": "array", "items": {"$ref": "#/$defs/sourceAssertion"}},
    "actors": {"type": "array", "items": {"$ref": "#/$defs/actor"}},
    "states": {"type": "array", "items": {"$ref": "#/$defs/state"}},
    "events": {"type": "array", "items": {"$ref": "#/$defs/event"}},
    "timers": {"type": "array", "items": {"$ref": "#/$defs/timer"}},
    "transitions": {"type": "array", "items": {"$ref": "#/$defs/transition"}},
    "tasks": {"type": "array", "items": {"$ref": "#/$defs/task"}},
    "ruleInvocations": {"type": "array", "items": {"$ref": "#/$defs/ruleInvocation"}},
    "evidenceReferences": {"type": "array", "items": {"$ref": "#/$defs/evidenceReference"}},
    "traces": {"type": "array", "items": {"$ref": "#/$defs/trace"}},
    "exceptions": {"type": "array", "items": {"$ref": "#/$defs/exception"}}
  },
  "$defs": {
    "picId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*(/[a-z0-9][a-z0-9_.-]*)*$"},
    "semver": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "refIds": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/picId"}},
    "sourceAssertion": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "authority", "sourceType", "reviewStatus", "assertion", "sourceUri", "retrievedAt", "effectiveFrom", "controlling"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "authority": {"enum": ["law", "regulation", "national_policy", "regional_policy", "guidance", "interpretation", "runtime_observation"]},
        "sourceType": {"enum": ["official_primary", "official_secondary", "secondary", "runtime_record"]},
        "reviewStatus": {"enum": ["agent-proposed", "human-approved", "official-primary", "rejected"]},
        "assertion": {"type": "string", "minLength": 1},
        "sourceUri": {"type": "string", "format": "uri"},
        "retrievedAt": {"type": "string", "format": "date-time"},
        "effectiveFrom": {"type": ["string", "null"], "format": "date"},
        "effectiveTo": {"type": ["string", "null"], "format": "date"},
        "controlling": {"type": "boolean"}
      }
    },
    "state": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "label"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "kind": {"enum": ["initial", "intermediate", "terminal"]},
        "label": {"type": "string", "minLength": 1},
        "sourceAssertionIds": {"$ref": "#/$defs/refIds"}
      }
    },
    "actor": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "name"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "kind": {"enum": ["person", "role", "organization", "system"]},
        "name": {"type": "string", "minLength": 1},
        "authoritySourceAssertionIds": {"$ref": "#/$defs/refIds"}
      }
    },
    "event": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "eventType", "occurredAt", "sourceAssertionIds"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "kind": {"enum": ["observed_event", "derived_state", "proposed_action", "certified_human_decision", "executed_action"]},
        "eventType": {"type": "string", "minLength": 1},
        "occurredAt": {"type": "string", "format": "date-time"},
        "observedAt": {"type": "string", "format": "date-time"},
        "actorId": {"$ref": "#/$defs/picId"},
        "timerId": {"$ref": "#/$defs/picId"},
        "sourceAssertionIds": {"$ref": "#/$defs/refIds"},
        "evidenceReferenceIds": {"$ref": "#/$defs/refIds"}
      }
    },
    "timer": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "name", "startEventId", "sourceAssertionIds"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "kind": {"enum": ["calendar_duration", "working_day_duration", "deadline", "relative"]},
        "name": {"type": "string", "minLength": 1},
        "startEventId": {"$ref": "#/$defs/picId"},
        "duration": {"type": "string", "minLength": 1},
        "calendarId": {"type": "string", "minLength": 1},
        "sourceAssertionIds": {"$ref": "#/$defs/refIds"}
      }
    },
    "transition": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "fromStateId", "toStateId", "triggerEventId"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "fromStateId": {"$ref": "#/$defs/picId"},
        "toStateId": {"$ref": "#/$defs/picId"},
        "triggerEventId": {"$ref": "#/$defs/picId"},
        "taskId": {"$ref": "#/$defs/picId"},
        "sourceAssertionIds": {"$ref": "#/$defs/refIds"}
      }
    },
    "task": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "name"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "kind": {"enum": ["human_task", "deterministic_rule_task", "evidence_task"]},
        "name": {"type": "string", "minLength": 1},
        "actorRole": {"type": "string", "minLength": 1},
        "ruleInvocationId": {"$ref": "#/$defs/picId"},
        "decisionEventId": {"$ref": "#/$defs/picId"},
        "sourceAssertionIds": {"$ref": "#/$defs/refIds"}
      }
    },
    "ruleInvocation": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "ruleId", "deterministic", "fixtureRef", "parameterRefs", "traceId"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "ruleId": {"$ref": "#/$defs/picId"},
        "deterministic": {"const": true},
        "fixtureRef": {"type": "string", "pattern": "^pic-fixtures/[0-9]+\\.[0-9]+\\.[0-9]+#.+$"},
        "parameterRefs": {"type": "array", "items": {"type": "string", "pattern": "^pic-parameters/[0-9]+\\.[0-9]+\\.[0-9]+#.+$"}},
        "traceId": {"$ref": "#/$defs/picId"}
      }
    },
    "evidenceReference": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "uri", "sha256", "sourceAssertionIds"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "uri": {"type": "string", "format": "uri"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "sourceAssertionIds": {"$ref": "#/$defs/refIds"}
      }
    },
    "trace": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "traceContract", "artifactRef", "eventIds", "ruleInvocationIds", "equivalenceClaim"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "traceContract": {"type": "string", "pattern": "^pic-traces/[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "artifactRef": {"type": "string", "minLength": 1},
        "eventIds": {"$ref": "#/$defs/refIds"},
        "ruleInvocationIds": {"$ref": "#/$defs/refIds"},
        "equivalenceClaim": {"enum": ["output", "path", "semantic", "none"]},
        "lossNotes": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "exception": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "kind", "description"],
      "properties": {
        "id": {"$ref": "#/$defs/picId"},
        "kind": {"enum": ["unsupported_mapping", "source_conflict", "missing_time", "platform_loss", "human_adjudication_required"]},
        "description": {"type": "string", "minLength": 1}
      }
    }
  }
}
